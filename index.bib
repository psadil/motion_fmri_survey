@article{wheatley_understanding_2007,
  title = {Understanding {{Animate Agents}}: {{Distinct Roles}} for the {{Social Network}} and {{Mirror System}}},
  shorttitle = {Understanding {{Animate Agents}}},
  author = {Wheatley, Thalia and Milleville, Shawn C. and Martin, Alex},
  year = {2007},
  month = jun,
  journal = {Psychological Science},
  volume = {18},
  number = {6},
  pages = {469--474},
  issn = {0956-7976, 1467-9280},
  doi = {10.1111/j.1467-9280.2007.01923.x},
  urldate = {2022-08-03},
  abstract = {How people understand the actions of animate agents has been vigorously debated. This debate has centered on two hypotheses focused on anatomically distinct neural substrates: The mirror-system hypothesis proposes that the understanding of others is achieved via action simulation, and the social-network hypothesis proposes that such understanding is achieved via the integration of critical biological properties (e.g., faces, affect). In this study, we assessed the areas of the brain that were engaged when people interpreted and imagined moving shapes as animate or inanimate. Although observing and imagining the moving shapes engaged the mirror system, only activation of the social network was modulated by animacy.},
  langid = {english}
}

